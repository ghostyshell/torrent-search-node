# Environment Configuration
NODE_ENV=development

# Server Configuration
PORT=3001
HOST=0.0.0.0

# Database Configuration
# For local development, leave Turso variables empty to use local SQLite
# For production, set these to use Turso cloud database
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Force cloud database even in development (optional)
FORCE_CLOUD_DB=false

# Google API Configuration
GOOGLE_SERVICE_ACCOUNT_PATH=./path/to/service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
GOOGLE_CUSTOM_SEARCH_API_KEY=

# CORS Configuration
FRONTEND_URL=http://localhost:3000
# Additional CORS origins (comma-separated)
ADDITIONAL_CORS_ORIGINS=

# API Keys
REAL_DEBRID_API_KEY=
SHOTSTACK_API_KEY=

# Production-specific settings
# Set these in production environment
# FRONTEND_URL=https://your-frontend-domain.com
# ADDITIONAL_CORS_ORIGINS=https://admin.yourdomain.com,https://api-docs.yourdomain.com